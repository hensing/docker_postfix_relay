# Postfix Relay Configuration

# Your primary domain name (e.g., example.com)
DOMAIN=

# The FQDN of your mail server (e.g., smtp.example.com)
MYHOSTNAME=

# Host directory containing the TLS certificate + private key for MYHOSTNAME,
# provided by whatever ACME client you use (e.g. Caddy, Certbot, ...).
# Must contain the files referenced by CERT_FILE/KEY_FILE (see generate-configs.sh),
# by default fullchain.pem and privkey.pem. Mounted read-only into the container.
CERTS_DIR=./certs

# The address and port of the external SMTP relay (e.g., [smtp-relay.gmail.com]:587)
RELAY_HOST=[smtp-relay.gmail.com]:587


# The list of trusted networks that can use the relay
MYNETWORKS="127.0.0.0/8 [::1]/128"

# TLS log level for outgoing mail (0: Disable, 1: Summary, 2: Details, 3+: Verbose)
SMTP_TLS_LOGLEVEL=1

# TLS log level for incoming mail (0: Disable, 1: Summary, 2: Details, 3+: Verbose)
SMTPD_TLS_LOGLEVEL=1

# Rotate data/mail.log once it reaches this many bytes (copytruncate style,
# keeps MAIL_LOG_KEEP rotated generations as mail.log.1, mail.log.2, ...).
MAIL_LOG_MAX_BYTES=10485760
MAIL_LOG_KEEP=5
